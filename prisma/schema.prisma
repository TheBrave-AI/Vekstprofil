generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model question {
  q_id         Int      @id @default(autoincrement())
  id           String   @unique  // string slug e.g. "teamSize", "closeRate"
  category     String
  label        String
  help         String
  placeholder  String
  type         String           // "number" | "text" | "boolean" | "select" | "multiselect"
  prefix       String?
  suffix       String?
  options      Json?            // string[] for select/multiselect
  slider       Json?            // { min, max, step } for slider
  answers      answer[]
}

model template {
  t_id           Int             @id @default(autoincrement())
  question_ids   Json
  title          String
  description    String?
  short_title    String?
  questionnaires questionnaire[]
}

model customer {
  c_id           Int             @id @default(autoincrement())
  name           String
  questionnaires questionnaire[]
}

model questionnaire {
  qu_id      Int      @id @default(autoincrement())
  t_id       Int
  c_id       Int
  answer_ids Json?
  link       String   @unique
  template   template @relation(fields: [t_id], references: [t_id])
  customer   customer @relation(fields: [c_id], references: [c_id])
}

model answer {
  a_id     Int      @id @default(autoincrement())
  q_id     Int
  value    String?
  empty    Boolean  @default(false)
  question question @relation(fields: [q_id], references: [q_id])
}

// Auth.js (NextAuth v5) — required by the Prisma adapter
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
