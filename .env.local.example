# ── Local development ─────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://braveai@localhost:5432/brave_onboarding"

# ── Production (Neon / Vercel Postgres) ───────────────────────────────────────
# sslmode=require is mandatory for Neon and Vercel Postgres
DATABASE_URL="postgresql://user:password@host:5432/brave_onboarding?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# On Vercel: AUTH_URL is auto-inferred from VERCEL_URL — only set it manually
# if deploying to a custom domain or a non-Vercel host.
# AUTH_URL="https://onboarding.thebrave.no"

# Google OAuth — create at console.cloud.google.com
# Authorised redirect URIs to register:
#   Dev:  http://localhost:3000/api/auth/callback/google
#   Prod: https://onboarding.thebrave.no/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
